<Window x:Class="ClaudeSessionsSidekick.ClaudeConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        Title="Memory Manager"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Dark theme for Markdig.Wpf FlowDocument rendering -->
        <Style TargetType="FlowDocument" x:Key="{x:Static markdig:Styles.DocumentStyleKey}">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Paragraph" x:Key="{x:Static markdig:Styles.Heading1StyleKey}">
            <Setter Property="Foreground" Value="#A0B0FF"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,8,0,6"/>
        </Style>
        <Style TargetType="Paragraph" x:Key="{x:Static markdig:Styles.Heading2StyleKey}">
            <Setter Property="Foreground" Value="#A0B0FF"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style TargetType="Paragraph" x:Key="{x:Static markdig:Styles.Heading3StyleKey}">
            <Setter Property="Foreground" Value="#B0C0FF"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,4"/>
        </Style>
        <Style TargetType="Paragraph" x:Key="{x:Static markdig:Styles.CodeBlockStyleKey}">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#C0D0C0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
        <Style TargetType="Run" x:Key="{x:Static markdig:Styles.CodeStyleKey}">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#C0D0C0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Hyperlink" x:Key="{x:Static markdig:Styles.HyperlinkStyleKey}">
            <Setter Property="Foreground" Value="#6FAAEF"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="SelectionBrush" Value="#3A3A6A"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A5A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <Border x:Name="Bd" Background="#3A3A5A"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}" CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A3A"/>
                                <Setter Property="Foreground" Value="#555566"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#35354A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Dark scrollbar -->
        <Style x:Key="DarkThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#404060" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#1A1A2A" CornerRadius="5">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Width" Value="Auto"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- System color overrides -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A3A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A6A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#303050"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E0E0E0"/>

        <!-- Dark ComboBox -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="18"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A3A"
                        BorderBrush="#40606080" BorderThickness="1" CornerRadius="2"/>
                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="#888899"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,20,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" TextBlock.Foreground="#E0E0E0"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#2A2A3A" BorderBrush="#40606080" BorderThickness="1"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ListBox item -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A6A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#303050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#A0A0B0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="#252535"
                                BorderBrush="#40606080" BorderThickness="1,1,1,0"
                                Margin="0,0,2,0" CornerRadius="3,3,0,0">
                            <ContentPresenter ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5A"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#303050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Memory Manager" FontSize="15" FontWeight="Bold"
                       Foreground="#A0B0FF" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtStatus" Foreground="#888899" FontSize="12"
                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </DockPanel>

        <TabControl x:Name="tabMain" Grid.Row="1">

            <!-- Tab 1: CLAUDE.md editor -->
            <TabItem Header="Memory  (CLAUDE.md)">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Scope picker -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="cmbScope" Width="380" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="CmbScope_SelectionChanged"
                                      ToolTip="Pick which CLAUDE.md to edit"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" x:Name="txtFilePath" Foreground="#666677" FontSize="11"
                                   VerticalAlignment="Center" Margin="14,0,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="TxtFilePath_Click"
                                   ToolTip="Click to open this file in your default editor">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#666677"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#A0B0FF"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Content editor / preview -->
                    <Grid Grid.Row="1">
                        <TextBox x:Name="txtContent"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"
                                 TextChanged="TxtContent_TextChanged"/>
                        <markdig:MarkdownViewer x:Name="mdContentPreview" Visibility="Collapsed"/>
                    </Grid>

                    <!-- Save / Cancel -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <TextBlock x:Name="txtCharCount" Foreground="#666677" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Insert Template" Click="BtnInsertTemplate_Click"
                                ToolTip="Insert a starter CLAUDE.md skeleton with common sections&#x0a;(build commands, architecture, coding conventions, testing).&#x0a;Appends to existing content — won't overwrite."
                                Margin="0,0,6,0"/>
                        <CheckBox x:Name="chkContentPreview" Content="Preview" Foreground="#A0A0B0"
                                  VerticalAlignment="Center" Margin="0,0,12,0"
                                  Checked="ChkContentPreview_Changed" Unchecked="ChkContentPreview_Changed"/>
                        <CheckBox x:Name="chkWordWrap" Content="Wrap" Foreground="#A0A0B0"
                                  VerticalAlignment="Center" Margin="0,0,12,0"
                                  Checked="ChkWordWrap_Changed" Unchecked="ChkWordWrap_Changed"
                                  ToolTip="Toggle word wrap in the editor"/>
                        <Button Content="Reload" Click="BtnReload_Click"
                                ToolTip="Discard unsaved changes and reload from disk"/>
                        <Button x:Name="btnSaveClaudeMd" Content="Save" Click="BtnSaveClaudeMd_Click"
                                Padding="20,5" Margin="8,0,0,0" FontWeight="SemiBold" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Auto-memory viewer -->
            <TabItem Header="Auto-memory  (MEMORY.md)"
                     ToolTip="Claude automatically saves facts it learns during conversations&#x0a;(your preferences, project context, corrections you give it).&#x0a;&#x0a;These are stored as individual .md files in ~/.claude/projects/&lt;project&gt;/memory/.&#x0a;MEMORY.md is the index that Claude loads at the start of every conversation.">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Explainer -->
                    <TextBlock Grid.Row="0" Foreground="#888899" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10">
                        Claude saves facts it learns from your conversations (coding preferences, project context, corrections).
                        Each entry is a .md file. MEMORY.md is the index Claude reads at the start of every session.
                        You wrote CLAUDE.md — Claude writes these.
                    </TextBlock>

                    <!-- Project + search -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="cmbMemProject" Width="380" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="CmbMemProject_SelectionChanged"
                                      ToolTip="Each Claude Code project has its own auto-memory folder.&#x0a;Select a project to browse its saved entries."/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ComboBox x:Name="cmbMemType" Width="100" Style="{StaticResource DarkCombo}"
                                  SelectionChanged="CmbMemType_SelectionChanged" Margin="0,0,8,0"
                                  ToolTip="Filter by memory type"/>
                        <Grid>
                            <TextBox x:Name="txtMemSearch" Width="180"
                                     VerticalContentAlignment="Center" Padding="6,3"
                                     TextChanged="TxtMemSearch_TextChanged"
                                     ToolTip="Filter by name, description, or body text"/>
                            <TextBlock Text="Search..." IsHitTestVisible="False"
                                       Foreground="#606070" FontSize="12" Margin="9,4,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=txtMemSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Memory dir path -->
                    <TextBlock Grid.Row="2" x:Name="txtMemDirPath" Foreground="#666677" FontSize="11"
                               Margin="0,0,0,8"
                               TextTrimming="CharacterEllipsis"
                               Cursor="Hand"
                               MouseLeftButtonUp="TxtMemDirPath_Click"
                               ToolTip="Click to open the memory folder in Explorer">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#666677"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#A0B0FF"/>
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: entry list -->
                        <Grid Grid.Column="0" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox x:Name="lstMemEntries" Grid.Row="0"
                                     Background="#252535" BorderBrush="#40606080" BorderThickness="1"
                                     SelectionMode="Extended"
                                     SelectionChanged="LstMemEntries_SelectionChanged"
                                     ToolTip="Individual memory entries that Claude saved from your conversations.&#x0a;Types: user (about you), feedback (your corrections), project (work context), reference (external pointers).&#x0a;Right-click for actions. Ctrl/Shift+click to select multiple for batch delete."
                                     >
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,3">
                                            <DockPanel>
                                                <TextBlock Text="{Binding LastModifiedDisplay}" FontSize="10"
                                                           Foreground="#666677" DockPanel.Dock="Right" Margin="4,1,0,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="#E0E0E0" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <Border Background="#2E3448" CornerRadius="2" Padding="4,1">
                                                    <TextBlock Text="{Binding Type}" FontSize="10"
                                                               Foreground="#A0B0FF"/>
                                                </Border>
                                                <TextBlock Text="{Binding Description}" FontSize="10"
                                                           Foreground="#888899" Margin="6,0,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ContextMenu>
                                    <ContextMenu Background="#2A2A3A" BorderBrush="#40606080" Foreground="#E0E0E0">
                                        <MenuItem Header="Open file in editor" Click="MenuOpenMemFile_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Delete entry" Click="MenuDeleteMem_Click" Foreground="#E08080"/>
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                            </ListBox>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="btnDeleteMem" Content="Delete selected" Click="BtnDeleteMem_Click"
                                        IsEnabled="False" Foreground="#E08080" Padding="10,4"
                                        ToolTip="Delete selected entries. Use Ctrl+click or Shift+click to select multiple."/>
                                <Button Content="View MEMORY.md" Click="BtnViewMemoryIndex_Click"
                                        Margin="6,0,0,0" Padding="8,4"
                                        ToolTip="Show the MEMORY.md index file that Claude reads&#x0a;at the start of every conversation in this project.&#x0a;This is the table of contents pointing to the individual entries."/>
                                <Button Content="Refresh" Click="BtnRefreshMem_Click"
                                        Margin="6,0,0,0" Padding="8,4"/>
                            </StackPanel>
                        </Grid>

                        <!-- Right: entry preview -->
                        <Border Grid.Column="1" Background="#252535" BorderBrush="#40606080" BorderThickness="1"
                                CornerRadius="4" Padding="12,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" x:Name="txtMemName" FontSize="14" FontWeight="Bold"
                                           Foreground="#A0B0FF" TextWrapping="Wrap"
                                           Text="(select a memory entry on the left)"/>
                                <TextBlock Grid.Row="1" x:Name="txtMemMeta" FontSize="11"
                                           Foreground="#888899" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" x:Name="txtMemDescription" FontSize="11"
                                           Foreground="#A0A0B0" TextWrapping="Wrap" Margin="0,6,0,8"/>
                                <DockPanel Grid.Row="3">
                                    <CheckBox x:Name="chkMemPreview" DockPanel.Dock="Top"
                                              Content="Formatted preview" Foreground="#888899" FontSize="11"
                                              Margin="0,0,0,4" Checked="ChkMemPreview_Changed" Unchecked="ChkMemPreview_Changed"/>
                                    <Grid>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox x:Name="txtMemBody"
                                                     IsReadOnly="True" Background="Transparent"
                                                     BorderThickness="0" Foreground="#E0E0E0"
                                                     FontFamily="Consolas" FontSize="12"
                                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                                        </ScrollViewer>
                                        <markdig:MarkdownViewer x:Name="mdMemBody"
                                                                Visibility="Collapsed"/>
                                    </Grid>
                                </DockPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
