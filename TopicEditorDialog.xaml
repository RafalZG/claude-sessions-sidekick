<Window x:Class="ClaudeSessionsSidekick.TopicEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Topic"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Border CornerRadius="8" Background="#252535" BorderBrush="#40606080" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Custom topic for session" FontSize="14" FontWeight="Bold"
                       Foreground="#A0B0FF" Margin="0,0,0,4"/>
            <TextBlock x:Name="txtSessionLabel" Grid.Row="1" FontSize="11"
                       Foreground="#888899" TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,10"/>

            <TextBox x:Name="txtTopic" Grid.Row="2"
                     Background="#1E1E2E" Foreground="#E0E0E0" BorderBrush="#40606080"
                     BorderThickness="1" Padding="8,6" FontSize="13"
                     SpellCheck.IsEnabled="False"
                     MaxLength="200"/>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock DockPanel.Dock="Left" Foreground="#606070" FontSize="11"
                           VerticalAlignment="Center"
                           Text="Esc to cancel  |  Enter to save  |  Empty to clear"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="BtnCancel_Click"
                            Background="#3A3A5A" Foreground="#E0E0E0"
                            BorderBrush="#40606080" BorderThickness="1"
                            Padding="16,6" Cursor="Hand" Margin="0,0,8,0"/>
                    <Button Content="Save" Click="BtnSave_Click"
                            Background="#3A5A3A" Foreground="#C0F0C0"
                            BorderBrush="#406040" BorderThickness="1"
                            Padding="16,6" Cursor="Hand" FontWeight="SemiBold"
                            IsDefault="True"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
