<Window x:Class="ClaudeSessionsSidekick.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Sessions Sidekick — Settings"
        Width="560" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A5A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A3A"/>
                                <Setter Property="Foreground" Value="#555566"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#35354A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Dark rounded ScrollBar -->
        <Style x:Key="DarkThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="4" Background="#404060" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#1A1A2A" CornerRadius="5">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Override system colors for ComboBox dropdown popup -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A3A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A6A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E0E0E0"/>

        <!-- Dark ComboBox toggle button -->
        <ControlTemplate x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="18"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A3A"
                        BorderBrush="#40606080" BorderThickness="1" CornerRadius="2"/>
                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="#888899"/>
            </Grid>
        </ControlTemplate>

        <!-- Dark ComboBox style -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,20,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextBlock.Foreground="#E0E0E0"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2A2A3A"
                                            BorderBrush="#40606080" BorderThickness="1"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ListBox item style -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A6A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#303050"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#252535"/>
                    <Setter Property="Foreground" Value="#A0A0B0"/>
                    <Setter Property="Padding" Value="14,5"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Background="#252535"
                                        BorderBrush="#40606080" BorderThickness="1,1,1,0"
                                        Margin="0,0,2,0" CornerRadius="3,3,0,0">
                                    <ContentPresenter ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3A3A5A"/>
                                        <Setter Property="Foreground" Value="#E0E0E0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#303050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="TabControl">
                    <Setter Property="Background" Value="#1E1E2E"/>
                    <Setter Property="BorderBrush" Value="#40606080"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </TabControl.Resources>

            <!-- Tab 0: General -->
            <TabItem Header="General">
                <StackPanel Margin="0,16,0,0">
                    <Border Background="#252535" BorderBrush="#40606080" BorderThickness="1"
                            CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Shell:" VerticalAlignment="Center" Margin="0,0,12,8"
                                       ToolTip="Which shell to use when launching Claude Code.&#x0a;&#x0a;Auto-detect: picks the first shell where 'claude' is in PATH&#x0a;CMD: Windows Command Prompt&#x0a;PowerShell: PowerShell 7 or Windows PowerShell&#x0a;Git Bash: Git for Windows bash"/>
                            <ComboBox x:Name="cmbShell" Grid.Row="0" Grid.Column="1" Width="160"
                                      Style="{StaticResource DarkCombo}" Margin="0,0,0,8" HorizontalAlignment="Left"
                                      ToolTip="Which shell to use when launching Claude Code sessions.&#x0a;&#x0a;Auto: detect which shell has 'claude' in PATH&#x0a;CMD: Windows Command Prompt&#x0a;PowerShell: PowerShell 7 or Windows PowerShell&#x0a;Git Bash: Git for Windows bash"/>
                            <TextBlock x:Name="txtShellDetected" Grid.Row="0" Grid.Column="2" Foreground="#888899"
                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,8"/>

                            <TextBlock x:Name="lblClaudePath" Grid.Row="1" Grid.Column="0" Text="Claude path:"
                                       VerticalAlignment="Center" Margin="0,0,0,8"
                                       ToolTip="Path to claude.exe if it's not in your PATH.&#x0a;Leave empty for auto-detection."/>
                            <TextBox x:Name="txtClaudeExe" Grid.Row="1" Grid.Column="1" Margin="0,0,6,8"
                                     ToolTip="Leave empty to auto-detect.&#x0a;Set only if 'claude' is not found in PATH.&#x0a;&#x0a;Common locations:&#x0a;  • npm: %APPDATA%\npm\claude.cmd&#x0a;  • WinGet: %LOCALAPPDATA%\Microsoft\WinGet\Links\claude.exe"/>
                            <Button x:Name="btnBrowseExe" Grid.Row="1" Grid.Column="2" Content="..." Padding="8,4"
                                    Click="BtnBrowseExe_Click" Margin="0,0,0,8"/>

                            <TextBlock x:Name="txtClaudeResolved" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                       Foreground="#60A060" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>

                            <TextBlock x:Name="txtClaudeNotFound" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                       Foreground="#E8A030" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                                       Visibility="Collapsed"/>

                            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                    Height="1" Background="#30606080" Margin="0,4,0,8"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Config directory:" VerticalAlignment="Center" Margin="0,0,0,8"
                                       ToolTip="Claude Code configuration directory (~/.claude).&#x0a;Contains credentials, sessions, plugins, and settings.&#x0a;&#x0a;Override if auto-detected path is wrong&#x0a;(e.g. domain-joined machines where USERPROFILE&#x0a;has a suffix like .MONITOR or .DOMAIN)."/>
                            <TextBox x:Name="txtClaudeHome" Grid.Row="5" Grid.Column="1" Margin="0,0,6,8"/>
                            <Button x:Name="btnBrowseHome" Grid.Row="5" Grid.Column="2" Content="..." Padding="8,4"
                                    Click="BtnBrowseHome_Click" Margin="0,0,0,8"/>

                            <TextBlock x:Name="txtClaudeHomeStatus" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                                       FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>

                            <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3"
                                    Height="1" Background="#30606080" Margin="0,4,0,8"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Default model:" VerticalAlignment="Center" Margin="0,0,12,4"
                                       ToolTip="Model configured in Claude Code settings.json.&#x0a;Determines the context window size.&#x0a;&#x0a;Empty/not set = latest recommended model (1M context).&#x0a;Shorthand like 'opus' = older version (200k context)."/>
                            <TextBlock x:Name="txtDetectedModel" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,0,4" TextWrapping="Wrap"
                                       Cursor="Hand" MouseLeftButtonDown="TxtDetectedModel_Click"
                                       ToolTip="Click to open the settings file in your editor"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- Tab 1: Quick Launch Projects -->
            <TabItem Header="Quick Launch">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock x:Name="txtQuickLaunchWarning" Foreground="#E8A030" FontSize="11"
                                   Visibility="Collapsed"
                                   Text="⚠ Shortcuts are disabled — enable via tray menu 'Enable App Shortcuts'"/>
                    </DockPanel>

                    <TextBlock Grid.Row="1" Foreground="#888899" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8">
                        Launch Claude Code in a project folder via hotkey or tray menu. Point to your source code directory, not an executable.
                    </TextBlock>

                    <!-- Project list -->
                    <Border Grid.Row="2" Background="#252535" BorderBrush="#40606080" BorderThickness="1"
                            CornerRadius="4" Padding="0">
                        <ListBox x:Name="lstEntries" Background="Transparent" BorderThickness="0"
                                 Foreground="#E0E0E0" SelectionChanged="LstEntries_SelectionChanged"
                                 PreviewMouseLeftButtonDown="LstEntries_PreviewMouseDown"
                                 HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                                            <TextBlock Text="{Binding FolderPath}" FontSize="10.5" Foreground="#888899"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Hotkey}" Foreground="#A0B0FF"
                                                   FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Separator -->
                    <Border Grid.Row="3" Height="1" Background="#30606080" Margin="0,8,0,0"/>

                    <!-- Edit form -->
                    <Grid Grid.Row="4" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Project path:" VerticalAlignment="Center"
                                   ToolTip="Path to your source code folder (e.g. C:\src\MyProject).&#x0a;Claude Code will open a terminal in this directory.&#x0a;Do NOT point to an .exe — this is a folder path."/>
                        <TextBox x:Name="txtFolder" Grid.Row="1" Grid.Column="1" Margin="0,0,6,6"
                                 TextChanged="TxtFolder_TextChanged"/>
                        <Button x:Name="btnBrowse" Grid.Row="1" Grid.Column="2" Content="..." Padding="8,4"
                                Click="BtnBrowse_Click" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txtFolderWarning" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Foreground="#E8A030" FontSize="10" Margin="0,0,0,4"
                                   Visibility="Collapsed"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Hotkey:" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,6">
                            <ComboBox x:Name="cmbMod1" Width="72" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="CmbMod_SelectionChanged"/>
                            <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                            <ComboBox x:Name="cmbMod2" Width="72" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="CmbMod_SelectionChanged"/>
                            <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                            <ComboBox x:Name="cmbKey" Width="60" Style="{StaticResource DarkCombo}"
                                      SelectionChanged="CmbMod_SelectionChanged"/>
                        </StackPanel>

                        <TextBlock x:Name="txtHotkeyWarning" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                   Foreground="#E8A030" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                                   Visibility="Collapsed"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Shell:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbEntryShell" Grid.Row="5" Grid.Column="1" Width="140"
                                  Style="{StaticResource DarkCombo}" Margin="0,0,0,6" HorizontalAlignment="Left"
                                  ToolTip="Shell for this project. 'Use global' inherits from General tab."/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Model:" VerticalAlignment="Center" Margin="0,0,0,6"
                                   ToolTip="Force a specific Claude model on every launch via --model.&#x0a;&#x0a;Default: let Claude Code decide (uses settings.json or last /model choice)&#x0a;Sonnet / Opus: 1M token context&#x0a;Haiku: 200k token context&#x0a;&#x0a;Useful when you've previously used /model to switch in a session and&#x0a;want every new launch in this project to start fresh on a chosen model."/>
                        <ComboBox x:Name="cmbEntryModel" Grid.Row="6" Grid.Column="1" Width="180"
                                  Style="{StaticResource DarkCombo}" Margin="0,0,0,6" HorizontalAlignment="Left"
                                  ToolTip="Force a specific Claude model on every launch.&#x0a;Default = no override (Claude picks)."/>

                        <CheckBox x:Name="chkContinue" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                                  Content="Continue last session (claude -c)" Margin="0,0,0,8"
                                  ToolTip="When checked, Claude will resume the most recent session for this project.&#x0a;When unchecked, a new session will be started each time."/>

                        <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnAdd" Content="Add" Click="BtnAdd_Click" Margin="0,0,6,0"/>
                            <Button x:Name="btnUpdate" Content="Update" Click="BtnUpdate_Click" Margin="0,0,6,0" IsEnabled="False"/>
                            <Button x:Name="btnRemove" Content="Remove" Click="BtnRemove_Click" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Global Shortcuts -->
            <TabItem Header="Global Shortcuts">
                <StackPanel Margin="0,16,0,0">
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="txtShortcutsWarning" Foreground="#E8A030" FontSize="11"
                                   Visibility="Collapsed"
                                   Text="Shortcuts are currently disabled — enable via tray menu 'Enable App Shortcuts'"/>
                    </DockPanel>
                    <Border Background="#252535" BorderBrush="#40606080" BorderThickness="1"
                            CornerRadius="4" Padding="12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Show / Hide:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="cmbWidgetMod1" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbWidgetMod2" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbWidgetKey" Width="60" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Browse Sessions:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="cmbBrowserMod1" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbBrowserMod2" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbBrowserKey" Width="60" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Prompt Library:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="cmbPromptMod1" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbPromptMod2" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbPromptKey" Width="60" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Permissions:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="cmbPermMod1" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbPermMod2" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbPermKey" Width="60" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Memory Manager:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="cmbClaudeMod1" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbClaudeMod2" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbClaudeKey" Width="60" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                            </StackPanel>

                            <!-- Warning -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Agents &amp; Skills:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                                <ComboBox x:Name="cmbAgentsMod1" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbAgentsMod2" Width="72" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                                <TextBlock Text=" + " VerticalAlignment="Center" Margin="2,0"/>
                                <ComboBox x:Name="cmbAgentsKey" Width="60" Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbGlobal_SelectionChanged"/>
                            </StackPanel>

                            <TextBlock x:Name="txtGlobalWarning" Grid.Row="6" Grid.ColumnSpan="2"
                                       Foreground="#E8A030" FontSize="11" TextWrapping="Wrap"
                                       Visibility="Collapsed" Margin="0,4,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- Tab 3: Compact Recommendations -->
            <TabItem Header="Compact Recommendations">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Foreground="#888899" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12">
                        Controls when the widget recommends running /compact to free up context space.
                        Every message includes the full conversation — the bigger the context, the more tokens consumed per turn.
                        Compacting summarizes old back-and-forth while keeping key decisions.
                    </TextBlock>
                    <Border Background="#252535" BorderBrush="#40606080" BorderThickness="1"
                            CornerRadius="4" Padding="12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sensitivity:" VerticalAlignment="Center" Margin="0,0,0,8"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="cmbAggressiveness" Width="140" Style="{StaticResource DarkCombo}"
                                          ToolTip="Controls when /compact recommendations appear.&#x0a;&#x0a;Conservative: only at &gt;80% context, fewer dynamic alerts&#x0a;Balanced: default thresholds (50%/75% + dynamic signals)&#x0a;Aggressive: warns early (30%+), lower thresholds for all signals"/>
                                <TextBlock x:Name="txtAggressivenessHint" Foreground="#888899" FontSize="11"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- Custom thresholds (visible only when Custom selected) -->
                            <StackPanel x:Name="panelCustomThresholds" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                        Visibility="Collapsed" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Warning at:" Width="100" Foreground="#999AAA" FontSize="11"/>
                                    <Slider x:Name="sliderWarning" Width="160" Minimum="10" Maximum="90"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="SliderThreshold_Changed"/>
                                    <TextBlock x:Name="txtWarningValue" Width="40" Foreground="#E8A030"
                                               FontSize="11" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Critical at:" Width="100" Foreground="#999AAA" FontSize="11"/>
                                    <Slider x:Name="sliderCritical" Width="160" Minimum="20" Maximum="95"
                                            TickFrequency="5" IsSnapToTickEnabled="True"
                                            ValueChanged="SliderThreshold_Changed"/>
                                    <TextBlock x:Name="txtCriticalValue" Width="40" Foreground="#E05050"
                                               FontSize="11" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Notifications:" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkNotifications" Grid.Row="2" Grid.Column="1"
                                      Content="Show tray notifications for warnings"
                                      ToolTip="Show a Windows notification when a session reaches warning or critical context levels.&#x0a;Off by default — the pulsing mood indicator in the widget header already signals this.&#x0a;Enable if you prefer explicit toasts."/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Permissions:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox x:Name="chkPermissionSuggestions" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                      Content="Suggest generalizing overly-specific permission rules"
                                      ToolTip="When Claude Code adds a narrow rule (e.g. 'cd /path &amp;&amp; grep pattern'),&#x0a;show a notification suggesting a broader rule (e.g. 'cd *' + 'grep *').&#x0a;Requires widget restart to take effect."/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Widget panel:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox x:Name="chkShowActiveSessions" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0"
                                      Content="Show active sessions and /compact suggestions in widget"
                                      ToolTip="When on, the widget shows a per-session token panel with inline /compact suggestions.&#x0a;When off, those rows and any related toast notifications are hidden — session tracking still runs in the background for the Session Browser."/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Updates:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <CheckBox x:Name="chkCheckForUpdatesOnStartup" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0"
                                      Content="Check for updates on startup"
                                      ToolTip="When on, the app checks GitHub for a newer version once every 8 hours after startup&#x0a;and shows a tray notification if one is available.&#x0a;When off, no automatic check runs — you can still trigger one manually from the tray menu (Check for updates...)."/>
                        </Grid>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Save & Close / Cancel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button x:Name="btnSave" Content="Save &amp; Close" Click="BtnSave_Click" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
