<Window x:Class="ClaudeSessionsSidekick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Sessions Sidekick"
        Width="280" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#3A3A4A"/>
            <Setter Property="Foreground" Value="#5B8DEF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="7"/>
                            <Border CornerRadius="7" Margin="0" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999AAA"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="PercentText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C0C0D0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Margin="4"
            Background="#E8202030" BorderBrush="#40606080" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="14,10,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock x:Name="txtTitle" Text="Claude Usage" Foreground="#A0B0FF" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Cursor="Hand"
                           MouseRightButtonDown="TxtTitle_RightClick"/>
                <!-- Mini stats (visible in Mini mode only, replaces full body) -->
                <TextBlock x:Name="txtMiniStats" Foreground="#C0C0D0" FontSize="12"
                           VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnRefresh" Content="&#x21BB;" FontSize="13"
                            Foreground="#888899" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,10,0" Click="BtnRefresh_Click"
                            ToolTip="Refresh now">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" Padding="2,0">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           Cursor="Hand"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnClose" Content="&#x2715;" FontSize="11"
                            Foreground="#888899" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="BtnClose_Click"
                            ToolTip="Hide to tray">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" Padding="2,0">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           Cursor="Hand"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </DockPanel>

            <!-- API error banner (shown when token expired / rate limited) -->
            <Border x:Name="panelApiError" Grid.Row="1" Visibility="Collapsed"
                    Background="#50E05050" CornerRadius="4" Padding="6,4" Margin="0,0,0,6">
                <TextBlock x:Name="txtApiError" Foreground="#E06060" FontSize="11"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Session (5h) -->
            <StackPanel x:Name="panelSession" Grid.Row="2" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock Text="Current session" Style="{StaticResource LabelText}"
                               ToolTip="Your 5-hour rolling usage window, shared across all Claude Code sessions.&#x0a;This is NOT a single terminal session — it's the Anthropic rate limit window.&#x0a;Resets every 5 hours from your first message in the window."/>
                    <TextBlock x:Name="txtSessionPercent" Text="--%" Style="{StaticResource PercentText}"/>
                </DockPanel>
                <ProgressBar x:Name="barSession" Style="{StaticResource UsageBar}" Value="0" Margin="0,3,0,2"/>
                <TextBlock x:Name="txtSessionReset" Text="Resets in --" Style="{StaticResource SubText}"/>
            </StackPanel>

            <!-- Separator -->
            <Border x:Name="separatorMain" Grid.Row="3" Height="1" Background="#30606080" Margin="0,0,0,8"/>

            <!-- Weekly - All models -->
            <StackPanel x:Name="panelWeekly" Grid.Row="4" Margin="0,0,0,8">
                <DockPanel>
                    <TextBlock Text="Weekly - All models" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtWeeklyPercent" Text="--%" Style="{StaticResource PercentText}"/>
                </DockPanel>
                <ProgressBar x:Name="barWeekly" Style="{StaticResource UsageBar}" Value="0" Margin="0,3,0,2"/>
                <TextBlock x:Name="txtWeeklyReset" Text="Resets --" Style="{StaticResource SubText}"/>
            </StackPanel>

            <!-- Weekly - Opus (for Max 5x) -->
            <StackPanel x:Name="panelOpus" Grid.Row="5" Margin="0,0,0,0" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock Text="Weekly - Opus" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="txtOpusPercent" Text="--%" Style="{StaticResource PercentText}"/>
                </DockPanel>
                <ProgressBar x:Name="barOpus" Style="{StaticResource UsageBar}" Value="0" Margin="0,3,0,2"
                             Foreground="#B070E0"/>
                <TextBlock x:Name="txtOpusReset" Text="Resets --" Style="{StaticResource SubText}"/>
            </StackPanel>

            <!-- Separator before tokens -->
            <Border x:Name="separatorTokens" Grid.Row="6" Height="1" Background="#30606080" Margin="0,8,0,8"
                    Visibility="Collapsed"/>

            <!-- Live Token Counter -->
            <StackPanel x:Name="panelTokens" Grid.Row="7" Visibility="Collapsed">
                <!-- Clickable aggregate header -->
                <Border x:Name="tokenHeader" Background="Transparent" Cursor="Hand"
                        MouseLeftButtonDown="TokenHeader_Click" Margin="0,0,0,4">
                    <DockPanel>
                        <TextBlock x:Name="txtTokenExpander" Text="&#x25B6;" FontSize="10"
                                   Foreground="#888899" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Active sessions" Style="{StaticResource LabelText}"
                                   ToolTip="Sessions with activity in the last 10 minutes.&#x0a;Idle sessions are hidden until new messages are sent.&#x0a;Click to expand per-session details."/>
                        <TextBlock x:Name="txtTokenSummary" Text="" Style="{StaticResource SubText}"
                                   HorizontalAlignment="Right" Margin="0,0,0,0"/>
                    </DockPanel>
                </Border>

                <!-- Expandable details (totals + sessions + recommendations) -->
                <StackPanel x:Name="panelSessionExpanded" Visibility="Collapsed">
                    <!-- Aggregate totals -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock x:Name="txtTokenTotals" Style="{StaticResource SubText}" FontSize="11"/>
                    </DockPanel>

                    <!-- Per-session details -->
                    <StackPanel x:Name="panelSessionDetails" Margin="0,4,0,0">
                    </StackPanel>

                    <!-- Compact recommendations -->
                    <StackPanel x:Name="panelRecommendations" Margin="0,4,0,0">
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        </Grid>
    </Border>
</Window>
