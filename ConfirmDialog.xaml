<Window x:Class="ClaudeSessionsSidekick.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        MaxHeight="600">

    <Border CornerRadius="8" Background="#252535" BorderBrush="#40606080" BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock x:Name="txtTitle" Grid.Row="0" FontSize="14" FontWeight="Bold"
                       Foreground="#A0B0FF" Margin="0,0,0,12"/>

            <!-- Message - scrollable so long previews don't overflow the screen -->
            <ScrollViewer Grid.Row="1" MaxHeight="450" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,16">
                <TextBlock x:Name="txtMessage" FontSize="12"
                           Foreground="#E0E0E0" TextWrapping="Wrap"/>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancel" Click="BtnCancel_Click"
                        Background="#3A3A5A" Foreground="#E0E0E0"
                        BorderBrush="#40606080" BorderThickness="1"
                        Padding="16,6" Cursor="Hand" Margin="0,0,8,0"/>
                <Button x:Name="btnConfirm" Content="Delete" Click="BtnConfirm_Click"
                        Background="#5A2A2A" Foreground="#F08080"
                        BorderBrush="#804040" BorderThickness="1"
                        Padding="16,6" Cursor="Hand" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
