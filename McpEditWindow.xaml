<Window x:Class="ClaudeSessionsSidekick.McpEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCP Server"
        Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A5A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#40606080"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A3A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A6A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E0E0E0"/>
    </Window.Resources>

    <StackPanel Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton x:Name="rbStdio" Content="stdio (local command)" Foreground="#E0E0E0"
                             GroupName="type" IsChecked="True" Checked="TransportType_Changed" Margin="0,0,16,0"
                             ToolTip="Runs a local process (node, python, dotnet, etc.)&#x0a;that communicates via stdin/stdout.&#x0a;&#x0a;Used for: database tools, DevOps integrations,&#x0a;local file processors, custom MCP servers."/>
                <RadioButton x:Name="rbHttp" Content="HTTP / SSE (remote)" Foreground="#E0E0E0"
                             GroupName="type" Checked="TransportType_Changed"
                             ToolTip="Connects to a remote MCP server over HTTP or&#x0a;Server-Sent Events (SSE).&#x0a;&#x0a;Used for: cloud services like GitHub, Linear,&#x0a;GitLab, or any hosted MCP endpoint."/>
            </StackPanel>

            <!-- stdio fields -->
            <TextBlock x:Name="lblCommand" Grid.Row="2" Grid.Column="0" Text="Command:" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <TextBox x:Name="txtCommand" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                     ToolTip="Executable to run. Examples: cmd, node, npx, python, dotnet"/>

            <TextBlock x:Name="lblArgs" Grid.Row="3" Grid.Column="0" Text="Arguments:" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <TextBox x:Name="txtArgs" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
                     ToolTip="Space-separated arguments. Example: /c npx -y @daghis/teamcity-mcp"/>

            <!-- http fields -->
            <TextBlock x:Name="lblUrl" Grid.Row="2" Grid.Column="0" Text="URL:" VerticalAlignment="Center"
                       Margin="0,0,0,8" Visibility="Collapsed"/>
            <TextBox x:Name="txtUrl" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Visibility="Collapsed"
                     ToolTip="MCP server endpoint URL. Example: https://mcp.linear.app/mcp"/>

            <!-- env vars -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Env vars:" VerticalAlignment="Top" Margin="0,0,0,8"
                       ToolTip="One per line: KEY=VALUE"/>
            <TextBox x:Name="txtEnv" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                     ToolTip="One per line: KEY=VALUE&#x0a;Use ${VAR} for environment variable references&#x0a;&#x0a;Example:&#x0a;TEAMCITY_URL=http://10.0.0.55:8080&#x0a;TEAMCITY_TOKEN=your-token-here"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Headers:" VerticalAlignment="Top" Margin="0,0,0,8"
                       Visibility="{Binding Visibility, ElementName=lblUrl}"
                       ToolTip="One per line: Header-Name=value (for HTTP/SSE only)"/>
            <TextBox x:Name="txtHeaders" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="50"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                     Visibility="{Binding Visibility, ElementName=lblUrl}"
                     ToolTip="One per line: Header-Name=value&#x0a;Example: Authorization=Bearer ${GITHUB_TOKEN}"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Click="BtnSave_Click" FontWeight="SemiBold"/>
        </StackPanel>
    </StackPanel>
</Window>
